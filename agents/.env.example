# ── Databricks ────────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_databricks_pat_token
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=financial-intelligence

# ── LangSmith ─────────────────────────────────────────────────────────────────
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=financial-intelligence-platform

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8001

# ── Storage ───────────────────────────────────────────────────────────────────
BRONZE_PATH=s3://your-bucket/bronze/sec_filings/
SILVER_PATH=s3://your-bucket/silver/sec_chunks/

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
SEC_USER_AGENT=Your Name your@email.com
