"""
SEC Filing Ingestion — Bronze Layer
Downloads SEC 10-K and 10-Q filings and ingests them into
the Delta Lake Bronze layer using Apache Spark on Databricks.
Implements semantic chunking before handing off to the Silver layer.
"""

import os
import re
import time
import requests
import logging
from typing import List
from datetime import datetime
from pyspark.sql import SparkSession
from pyspark.sql.functions import lit, current_timestamp
from delta.tables import DeltaTable

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

# ── Config ────────────────────────────────────────────────────────────────────

SEC_EDGAR_BASE    = "https://data.sec.gov"
SEC_HEADERS       = {"User-Agent": os.environ.get("SEC_USER_AGENT", "hemanth@email.com")}

BRONZE_PATH       = os.environ.get("BRONZE_PATH", "s3://your-bucket/bronze/sec_filings/")
CHUNK_SIZE        = 512    # tokens per chunk (approximate)
CHUNK_OVERLAP     = 64     # overlap between chunks
REQUEST_DELAY     = 0.15   # SEC rate limit: 10 req/sec max

spark = SparkSession.builder.appName("sec-ingestion-bronze").getOrCreate()


# ── SEC EDGAR API ─────────────────────────────────────────────────────────────

def get_company_cik(ticker: str) -> str:
    """Resolve ticker to SEC CIK number."""
    url = f"{SEC_EDGAR_BASE}/submissions/CIK{ticker.upper()}.json"
    resp = requests.get(url, headers=SEC_HEADERS)
    resp.raise_for_status()
    return resp.json()["cik"]


def get_filing_urls(cik: str, filing_type: str = "10-K", count: int = 3) -> List[dict]:
    """Fetch filing URLs from SEC EDGAR for a given CIK and form type."""
    url = f"{SEC_EDGAR_BASE}/submissions/CIK{str(cik).zfill(10)}.json"
    resp = requests.get(url, headers=SEC_HEADERS)
    resp.raise_for_status()
    data = resp.json()

    filings = data.get("filings", {}).get("recent", {})
    forms       = filings.get("form", [])
    dates       = filings.get("filingDate", [])
    accessions  = filings.get("accessionNumber", [])

    results = []
    for form, date, acc in zip(forms, dates, accessions):
        if form == filing_type and len(results) < count:
            acc_clean = acc.replace("-", "")
            results.append({
                "filing_type": form,
                "filing_date": date,
                "accession": acc,
                "url": f"{SEC_EDGAR_BASE}/Archives/edgar/data/{cik}/{acc_clean}/{acc}-index.htm"
            })

    logger.info(f"Found {len(results)} {filing_type} filings for CIK {cik}")
    return results


def download_filing_text(url: str) -> str:
    """Download and return raw text from a filing URL."""
    time.sleep(REQUEST_DELAY)
    resp = requests.get(url, headers=SEC_HEADERS)
    resp.raise_for_status()

    # Strip HTML tags
    text = re.sub(r"<[^>]+>", " ", resp.text)
    text = re.sub(r"\s+", " ", text).strip()
    return text


# ── Semantic chunking ─────────────────────────────────────────────────────────

def semantic_chunk(text: str, chunk_size: int = CHUNK_SIZE, overlap: int = CHUNK_OVERLAP) -> List[str]:
    """
    Split filing text into overlapping chunks, preferring sentence boundaries.
    Approximate token count using word count / 0.75.
    """
    sentences = re.split(r"(?<=[.!?])\s+", text)
    chunks, current, current_len = [], [], 0

    for sentence in sentences:
        word_count = len(sentence.split())
        token_approx = int(word_count / 0.75)

        if current_len + token_approx > chunk_size and current:
            chunks.append(" ".join(current))
            # Keep last `overlap` tokens worth of sentences for context
            overlap_tokens = 0
            overlap_sentences = []
            for s in reversed(current):
                overlap_tokens += int(len(s.split()) / 0.75)
                overlap_sentences.insert(0, s)
                if overlap_tokens >= overlap:
                    break
            current = overlap_sentences
            current_len = sum(int(len(s.split()) / 0.75) for s in current)

        current.append(sentence)
        current_len += token_approx

    if current:
        chunks.append(" ".join(current))

    return chunks


# ── Bronze layer write ────────────────────────────────────────────────────────

def write_to_bronze(chunks: List[dict]):
    """Write raw chunks to Delta Lake Bronze layer with upsert (SCD-safe)."""
    df = spark.createDataFrame(chunks)
    df = df.withColumn("ingested_at", current_timestamp())

    if DeltaTable.isDeltaTable(spark, BRONZE_PATH):
        dt = DeltaTable.forPath(spark, BRONZE_PATH)
        dt.alias("target").merge(
            df.alias("source"),
            "target.chunk_id = source.chunk_id"
        ).whenNotMatchedInsertAll().execute()
        logger.info(f"[Bronze] Merged {len(chunks)} chunks into existing Delta table")
    else:
        df.write.format("delta").mode("overwrite").save(BRONZE_PATH)
        logger.info(f"[Bronze] Created new Delta table with {len(chunks)} chunks")


# ── Main ingestion pipeline ───────────────────────────────────────────────────

def ingest_ticker(ticker: str, filing_type: str = "10-K", years: int = 3):
    """
    Full ingestion pipeline for one ticker:
    1. Resolve CIK from EDGAR
    2. Fetch filing URLs
    3. Download + chunk text
    4. Write to Bronze Delta Lake
    """
    logger.info(f"[Ingestion] Starting {filing_type} ingestion for {ticker}")

    cik = get_company_cik(ticker)
    filings = get_filing_urls(cik, filing_type, count=years)

    all_chunks = []
    for filing in filings:
        logger.info(f"[Ingestion] Downloading {filing['filing_type']} filed {filing['filing_date']}")
        text = download_filing_text(filing["url"])
        chunks = semantic_chunk(text)

        for i, chunk_text in enumerate(chunks):
            all_chunks.append({
                "chunk_id": f"{ticker}_{filing['accession']}_{i:04d}",
                "ticker": ticker,
                "filing_type": filing["filing_type"],
                "filing_date": filing["filing_date"],
                "fiscal_year": f"FY{filing['filing_date'][:4]}",
                "accession": filing["accession"],
                "chunk_index": i,
                "total_chunks": len(chunks),
                "text": chunk_text,
                "source": filing["url"],
                "layer": "bronze"
            })

        logger.info(f"[Ingestion] {ticker} {filing['filing_date']}: {len(chunks)} chunks created")

    write_to_bronze(all_chunks)
    logger.info(f"[Ingestion] Complete: {len(all_chunks)} total chunks for {ticker}")
    return len(all_chunks)


if __name__ == "__main__":
    import argparse
    parser = argparse.ArgumentParser()
    parser.add_argument("--ticker", required=True, help="Stock ticker, e.g. AAPL")
    parser.add_argument("--type", default="10-K", help="Filing type: 10-K or 10-Q")
    parser.add_argument("--years", type=int, default=3, help="Number of filings to fetch")
    args = parser.parse_args()

    total = ingest_ticker(args.ticker, args.type, args.years)
    print(f"\nIngested {total} chunks for {args.ticker} into Bronze layer.")
    print(f"Next step: run silver transformation to embed and index into Pinecone.")
